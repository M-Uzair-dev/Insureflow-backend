# ─────────────────────────────────────────────────────────────
# InsureFlow backend environment — copy this file to `.env`
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas connection string (SRV). Get it from:
#   Atlas → Cluster → Connect → Drivers → copy the string,
#   then replace <user>/<pass> and keep the /insureflow db name.
MONGODB_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/insureflow?retryWrites=true&w=majority

# Port the API listens on
PORT=4000

# Where the Next.js frontend runs (used for CORS allow-origin)
CORS_ORIGIN=http://localhost:3000

# Local folder (relative to backend/) where uploaded documents are stored
UPLOAD_DIR=uploads

# Max size per uploaded file, in megabytes
MAX_UPLOAD_MB=10
